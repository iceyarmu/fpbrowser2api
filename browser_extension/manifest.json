{
  "manifest_version": 3,
  "name": "FPBrowser2API Task Executor",
  "version": "0.5.23",
  "description": "Execute VEO/Dreamina tasks from inside the fingerprint browser.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "cookies", "storage", "scripting", "alarms", "webRequest"],
  "host_permissions": [
    "http://*/*",
    "ws://*/*",
    "https://*/*",
    "https://labs.google/*",
    "https://*.google.com/*",
    "https://*.googleapis.com/*",
    "https://dreamina.capcut.com/*",
    "https://*.capcut.com/*",
    "https://*.capcutapi.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "FPBrowser2API",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "https://labs.google/*",
        "https://dreamina.capcut.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content/fpb_config_content.js"],
      "run_at": "document_idle"
    }
  ]
}
